<h1>Books form</h1>

<form action="/books/upsert" role="form" method="post">
  <div>
    <label for="title">Title</label>
    <input type="text" id="title" name="title" {{#if book}}value="{{book.title}}"{{/if}}>
  </div>
  <div>
    <label for="publishing_year">Publishing year</label>
    <input type="number" step="1" placeholder="2000" id="publishing_year" name="publishingYear" {{#if book}}value="{{book.publishingYear}}"{{/if}}>
  </div>
  <div class="mb-3">
    <label for="author_id">Author</label>
    <select multiple name="authorIds" id="author_id">
      <option value disabled selected> -- Please select an author --</option>
      {{#each authors}}
        <option value="{{@index}}" {{#if (in @root.book.authorIds @index)}} selected="true" {{/if}}>
          {{this.firstName}} {{this.lastName}}
        </option>
      {{/each}}
    </select>
  </div>
  {{#if book}}
    <input type="hidden" name="id" value="{{bookIdx}}">
  {{/if}}
  <button type="submit" class="btn btn-primary">Submit</button>
</form>
